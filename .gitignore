# ── Environment files — never commit secrets ──────────────────────────────────
.env
.env.*
**/.env
**/.env.*

# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
backend/server.log
backend/errors.log

# ── ChromaDB vector store ─────────────────────────────────────────────────────
# Included in repo so Railway has the embeddings without re-running ingest.
# backend/chroma_db/  ← kept out; only root-level chroma_db/ is tracked

# ── Document storage (PDFs and extracted text — keep off git) ─────────────────
documents/pdfs/
documents/extracted/

# ── Node / npm ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
